{% extends 'base.html.twig' %}

{% block title %}Party index{% endblock %}

{% block body %}
    <h1>Liste des groupes</h1>

    <form method="get" class="app-form">
        <div>
            <label for="party-status">Disponibilite</label>
            <select id="party-status" name="status">
                <option value="">Tous les groupes</option>
                <option value="available" {% if filters.status == 'available' %}selected{% endif %}>Avec places disponibles</option>
                <option value="full" {% if filters.status == 'full' %}selected{% endif %}>Complets</option>
            </select>
        </div>
        <div class="hero-actions">
            <button class="button" type="submit">Filtrer</button>
            <a class="text-link" href="{{ path('app_party_index') }}">Reinitialiser</a>
        </div>
    </form>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Description</th>
                <th>Taille max</th>
                <th>Createur</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for party in parties %}
            <tr>
                <td>{{ party.id }}</td>
                <td>{{ party.name }}</td>
                <td>{{ party.description }}</td>
                <td>{{ party.maxSize }}</td>
                <td>{{ party.user.username }}</td>
                <td>
                    <a href="{{ path('app_party_show', {'id': party.id}) }}">Voir</a>
                    <a href="{{ path('app_party_edit', {'id': party.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun groupe trouve.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_party_new') }}">Creer un groupe</a>
{% endblock %}
