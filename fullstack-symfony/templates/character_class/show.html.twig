{% extends 'base.html.twig' %}

{% block title %}CharacterClass{% endblock %}

{% block body %}
    <h1>CharacterClass</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ character_class.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ character_class.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ character_class.description }}</td>
            </tr>
            <tr>
                <th>HealthDice</th>
                <td>{{ character_class.healthDice }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_character_class_index') }}">back to list</a>

    <a href="{{ path('app_character_class_edit', {'id': character_class.id}) }}">edit</a>

    {{ include('character_class/_delete_form.html.twig') }}
{% endblock %}
