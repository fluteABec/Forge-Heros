{% extends 'base.html.twig' %}

{% block title %}Character index{% endblock %}

{% block body %}
    <section class="panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Personnages</p>
                <h1>Mes personnages</h1>
            </div>
            <a class="button" href="{{ path('app_character_new') }}">Creer un personnage</a>
        </div>

        <form method="get" action="{{ path('app_character_index') }}" class="app-form">
            <div>
                <label for="character-name">Nom</label>
                <input id="character-name" type="search" name="character_name" value="{{ filters.character_name }}">
            </div>
            <div>
                <label for="character-class">Classe</label>
                <select id="character-class" name="character_class_id">
                    <option value="">Toutes</option>
                    {% for character_class in character_classes %}
                        <option value="{{ character_class.id }}" {% if filters.character_class_id == character_class.id %}selected{% endif %}>
                            {{ character_class.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label for="character-race">Race</label>
                <select id="character-race" name="character_race_id">
                    <option value="">Toutes</option>
                    {% for race in races %}
                        <option value="{{ race.id }}" {% if filters.character_race_id == race.id %}selected{% endif %}>
                            {{ race.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="hero-actions">
                <button class="button" type="submit">Filtrer</button>
                <a class="text-link" href="{{ path('app_character_index') }}">Reinitialiser</a>
            </div>
        </form>

        <div class="character-card-grid">
        {% for character in characters %}
            <article class="card character-card">
                {% if character.image %}
                    <img
                        class="character-card-image"
                        src="{{ asset('uploads/characters/' ~ character.image) }}"
                        alt="{{ character.name }}"
                    >
                {% else %}
                    <div class="character-card-placeholder">
                        <span>No image</span>
                    </div>
                {% endif %}

                <div class="card-body character-card-body">
                    <div class="character-card-header">
                        <div>
                            <h2 class="character-card-title">{{ character.name }}</h2>
                            <p class="stat-label">Niveau {{ character.level }}</p>
                        </div>
                        <div class="character-hp-badge">{{ character.healthPoints }} PV</div>
                    </div>

                    <div class="character-stats-grid">
                        <article class="stat-card">
                            <p class="stat-label">STR</p>
                            <p class="stat-value-small">{{ character.strength }}</p>
                        </article>
                        <article class="stat-card">
                            <p class="stat-label">DEX</p>
                            <p class="stat-value-small">{{ character.dexterity }}</p>
                        </article>
                        <article class="stat-card">
                            <p class="stat-label">CON</p>
                            <p class="stat-value-small">{{ character.constitution }}</p>
                        </article>
                        <article class="stat-card">
                            <p class="stat-label">INT</p>
                            <p class="stat-value-small">{{ character.intelligence }}</p>
                        </article>
                        <article class="stat-card">
                            <p class="stat-label">WIS</p>
                            <p class="stat-value-small">{{ character.wisdom }}</p>
                        </article>
                        <article class="stat-card">
                            <p class="stat-label">CHA</p>
                            <p class="stat-value-small">{{ character.charisma }}</p>
                        </article>
                    </div>

                    <div class="hero-actions">
                        <a class="text-link" href="{{ path('app_character_show', {'id': character.id}) }}">Voir</a>
                        <a class="text-link" href="{{ path('app_character_edit', {'id': character.id}) }}">Modifier</a>
                    </div>
                </div>
            </article>
        {% else %}
            <p class="stat-label">Aucun personnage ne correspond aux filtres.</p>
        {% endfor %}
        </div>
    </section>
{% endblock %}
