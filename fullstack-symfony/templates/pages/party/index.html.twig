{% extends 'base.html.twig' %}

{% block title %}Groupes | Forge de Heros{% endblock %}

{% block body %}
    <section class="panel">
        <div class="panel-header">
            <h1>Groupes d'aventure</h1>
            <p>{{ parties|length }} resultat(s)</p>
        </div>
    </section>

    <section class="card-grid">
        {% for party in parties %}
            <article class="card card-compact">
                <div class="card-body">
                    <h2>{{ party.name }}</h2>
                    <p>{{ party.description }}</p>
                    <p>Taille max: {{ party.maxSize ?? 'Non definie' }}</p>
                    <a class="text-link" href="{{ path('app_party_show', { id: party.id }) }}">Voir le detail</a>
                </div>
            </article>
        {% else %}
            <p>Aucun groupe ne correspond aux filtres.</p>
        {% endfor %}
    </section>
{% endblock %}
