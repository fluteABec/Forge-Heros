{% extends 'base.html.twig' %}

{% block title %}Personnages | Forge de Heros{% endblock %}

{% block body %}
    <section class="panel">
        <div class="panel-header">
            <h1>Personnages</h1>
            <p>{{ characters|length }} resultat(s)</p>
        </div>

        <form class="filters" method="get">
            <label>
                Nom
                <input type="search" name="q" value="{{ filters.q }}" placeholder="Rechercher un personnage">
            </label>

            <button class="button" type="submit">Filtrer</button>
        </form>
    </section>

    <section class="card-grid">
        {% for character in characters %}
            <article class="card">
                {% set image = character.image ?: 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=600&q=80' %}
                <img src="{{ image }}" alt="Avatar de {{ character.name }}">
                <div class="card-body">
                    <h2>{{ character.name }}</h2>
                    <p>Niveau {{ character.level }} • {{ character.healthPoints }} PV</p>
                    <a class="text-link" href="{{ path('app_character_show', { id: character.id }) }}">Voir le detail</a>
                </div>
            </article>
        {% else %}
            <p>Aucun personnage ne correspond aux filtres.</p>
        {% endfor %}
    </section>
{% endblock %}
